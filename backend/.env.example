# Sample environment for the Scenarios App backend. Copy this to
# `.env` (gitignored) and fill in real values. See DESIGN.md Section 12.

# Required -- same Google API key the Pinyin Tool extension uses for its
# Gemini provider; one key powers both tools.
#
# Image search uses the keyless DuckDuckGo backend (ddgs package), so
# no second credential is needed.
GEMINI_API_KEY=

# Optional with defaults
DATABASE_URL=sqlite+aiosqlite:///./data/scenarios.db
IMAGE_STORAGE_DIR=./data/images
ALLOWED_ORIGINS=http://localhost:5173
LOG_LEVEL=INFO

# Set to 1 to opt into tests under tests/live/ that hit real external
# services. Off by default because those tests cost money and require
# network access.
RUN_LIVE_TESTS=
